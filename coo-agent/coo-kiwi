echo ""

# Step 1: Create order from input
echo "[Step 1/3] Creating order..."
ORDER_ID=$(node scripts/generate-kiwi-analysis.js "$INPUT" | grep "Order ID:" | tail -1 | awk '{print $3}')

if [ -z "$ORDER_ID" ]; then
    echo "❌ Failed to create order"
    exit 1
fi

echo "✅ Order created: $ORDER_ID"
echo ""

# Step 2: Process order (generate analysis)
echo "[Step 2/3] Generating AI analysis..."
python3 scripts/coo-process-kiwi-order.py "$ORDER_ID"

