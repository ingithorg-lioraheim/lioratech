set -e

# Change to script directory
cd "$(dirname "$0")"

# Check if input provided
if [ -z "$1" ]; then
    echo ""
    echo "❌ Error: No company data provided"
    echo ""
    echo "Usage:"
    echo "  ./coo-kiwi \"Company|Contact|Email|Equity|Year|Score|Priority|Industry|Website\""
    echo ""
